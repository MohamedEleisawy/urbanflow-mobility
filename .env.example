# =============================================================================
# UrbanFlow Mobility — variables d'environnement (modèle)
# =============================================================================
# Copiez ce fichier vers `.env` et renseignez les valeurs réelles.
# Le fichier `.env` n'est JAMAIS versionné (voir .gitignore).
# Aucune valeur ci-dessous n'est un secret : ce sont des exemples.
# =============================================================================

# ----------------------------- Général --------------------------------------
NODE_ENV=development

# ----------------------------- Frontend (Next.js) ---------------------------
# Préfixe NEXT_PUBLIC_ = exposé au navigateur : n'y mettre aucun secret.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ----------------------------- Backend (NestJS) -----------------------------
PORT=3001
CARBON_SERVICE_URL=http://localhost:8000

# ----------------------------- Carbon service (FastAPI) ---------------------
CARBON_ENVIRONMENT=development
CARBON_HOST=0.0.0.0
CARBON_PORT=8000
